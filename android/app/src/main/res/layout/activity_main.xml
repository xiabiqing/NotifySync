<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NotifySync"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="14dp"
            android:text="手机通知同步助手"
            android:textSize="14sp"
            android:textColor="@color/text_secondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="14dp">

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="状态: 检查中"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_request_permission"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/btn_primary"
                android:text="开启通知权限"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="连接设置"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="电脑 IP"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/et_ip"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/edit_text_bg"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:singleLine="true"
                android:text="192.168.43.1"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="端口"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/et_port"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/edit_text_bg"
                android:inputType="number"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:singleLine="true"
                android:text="8787"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="安全设置"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="安全 Token（可选，建议开启）"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/et_token"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/edit_text_bg"
                    android:hint="电脑端设置相同 Token"
                    android:inputType="textPassword"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:singleLine="true"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint" />

                <Button
                    android:id="@+id/btn_toggle_token"
                    android:layout_width="64dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/btn_secondary"
                    android:text="显示"
                    android:textAllCaps="false"
                    android:textColor="@color/primary"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btn_clear_token"
                    android:layout_width="64dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/btn_secondary"
                    android:text="清空"
                    android:textAllCaps="false"
                    android:textColor="@color/primary"
                    android:textSize="12sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_generate_token"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/btn_secondary"
                android:text="生成随机 Token"
                android:textAllCaps="false"
                android:textColor="@color/primary"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="加密密钥（可选，强烈建议）"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/et_crypto_key"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/edit_text_bg"
                    android:hint="与电脑端保持一致"
                    android:inputType="textPassword"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:singleLine="true"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint" />

                <Button
                    android:id="@+id/btn_toggle_crypto_key"
                    android:layout_width="64dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/btn_secondary"
                    android:text="显示"
                    android:textAllCaps="false"
                    android:textColor="@color/primary"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btn_clear_crypto_key"
                    android:layout_width="64dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/btn_secondary"
                    android:text="清空"
                    android:textAllCaps="false"
                    android:textColor="@color/primary"
                    android:textSize="12sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_generate_crypto_key"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/btn_secondary"
                android:text="生成随机加密密钥"
                android:textAllCaps="false"
                android:textColor="@color/primary"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="提示：这里的修改会实时自动保存并立即生效，无需手动保存"
                android:textColor="@color/warning"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="操作"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btn_test"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/btn_secondary"
                android:text="测试连接"
                android:textAllCaps="false"
                android:textColor="@color/primary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_test_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text=""
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="使用说明：1. 运行电脑端程序 2. 开启通知权限 3. 填写 IP 和端口 4. 点击测试"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:text="软件开发者：尼古拉.小侠碧青"
            android:textColor="@color/text_hint"
            android:textSize="12sp" />

    </LinearLayout>

</ScrollView>
