<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- 系统原生主题 → 不需要任何依赖 → 永远不会报错 -->
    <style name="AppTheme" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">#FFFFFF</item>
    </style>

    <!-- 卡片样式 -->
    <style name="CardStyle">
        <item name="android:layout_margin">12dp</item>
        <item name="android:padding">16dp</item>
        <item name="android:elevation">4dp</item>
        <item name="android:background">#FFFFFF</item>
    </style>

    <!-- 主按钮 -->
    <style name="PrimaryButton">
        <item name="android:padding">12dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:background">#2196F3</item>
    </style>

    <!-- 次按钮 -->
    <style name="SecondaryButton">
        <item name="android:padding">12dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#2196F3</item>
        <item name="android:background">#F5F5F5</item>
    </style>

    <!-- 输入框 -->
    <style name="EditTextStyle">
        <item name="android:padding">12dp</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:background">#F5F5F5</item>
    </style>

    <!-- 标题 -->
    <style name="TitleText">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#212121</item>
    </style>

    <!-- 副标题 -->
    <style name="SubtitleText">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#424242</item>
        <item name="android:layout_marginTop">16dp</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <!-- 正文 -->
    <style name="BodyText">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">#757575</item>
        <item name="android:lineSpacingMultiplier">1.3</item>
    </style>

</resources>